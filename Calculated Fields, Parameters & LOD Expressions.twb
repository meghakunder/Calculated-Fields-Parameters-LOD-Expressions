      <aliases enabled='yes' />
      <column caption='Delivery Satus' datatype='string' name='[Calculation_2005286453719040]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;= 30 then &quot;Fast&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Status' datatype='string' name='[Calculation_2005286462816257]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 Then &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Status 2' datatype='string' name='[Calculation_2005286494773250]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 50 THEN &quot;Low Profit&quot;&#13;&#10;ELSE &quot;High Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_2005286504583172]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))&lt;=[Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Sales per City (LOD)' datatype='real' name='[Calculation_2005286521450503]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED ([City]):AVG([Sales]) }' />
      </column>
      <column caption='Avg sales per product(INCLUDE)' datatype='real' name='[Calculation_2005286528806921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Product_Name]:AVG([Sales]) }' />
      </column>
